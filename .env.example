# ============================================================================
#  Poker CM — Telegram Poker Game — Environment Configuration
#  Copy this file to `.env` and adjust values before `docker compose up -d`.
# ============================================================================

# --- Telegram ---------------------------------------------------------------
# BotFather HTTP API token
BOT_TOKEN=123456:your-botfather-token-here
# Public base URL where the Mini App is served over HTTPS (no trailing slash).
# For local testing you can use a tunnel (cloudflared / ngrok) pointing at :8080.
PUBLIC_URL=https://your-domain.example
# Mini App URL (usually PUBLIC_URL). Used for the WebApp button.
WEBAPP_URL=https://your-domain.example
# Bot run mode: "polling" (no HTTPS needed) or "webhook" (needs HTTPS PUBLIC_URL)
BOT_MODE=polling
# Secret path token for the webhook endpoint (only used in webhook mode)
WEBHOOK_SECRET=change-me-to-a-random-string

# --- Security ---------------------------------------------------------------
# Secret used to sign session JWTs issued to the Mini App
SECRET_KEY=change-me-super-secret-key-please
# Comma separated Telegram user IDs that get admin powers
ADMIN_IDS=

# --- Database ---------------------------------------------------------------
POSTGRES_USER=poker
POSTGRES_PASSWORD=poker_secret
POSTGRES_DB=poker
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Economy ----------------------------------------------------------------
# Coins granted to a brand new player
SIGNUP_BONUS_COINS=10000
# Daily login reward base
DAILY_REWARD_COINS=1000
# TON wallet that receives payments (for TON top-ups)
TON_WALLET_ADDRESS=
# Conversion: coins granted per 1 Telegram Star
COINS_PER_STAR=1000

# --- Gameplay ---------------------------------------------------------------
# Seconds a player has to act before auto fold/check
TURN_TIMEOUT_SECONDS=25
# Seconds bots "think" before acting (min,max)
BOT_THINK_MIN=1.5
BOT_THINK_MAX=4.0

# --- App --------------------------------------------------------------------
ENV=production
LOG_LEVEL=INFO
